# Required: Supabase connection
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# These are set in Supabase Dashboard > Edge Functions > Secrets:
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# LOVABLE_API_KEY=your-lovable-api-key
# ALLOWED_ORIGIN=https://your-domain.com
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=outreach@yourdomain.com

# Sync Hub Integration
VITE_SYNCHUB_SUPABASE_URL=https://[sync-hub-project-ref].supabase.co
VITE_SYNCHUB_SUPABASE_ANON_KEY=[sync-hub-anon-key]
VITE_SYNCHUB_APP_ID=aisales
